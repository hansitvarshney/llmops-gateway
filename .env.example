# Copy to .env and fill in secrets. Never commit the real .env file.

APP_NAME=llmops-gateway
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_JSON=false

# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://llmops:llmops@localhost:5432/llmops_gateway
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_EXACT_CACHE_TTL_SECONDS=3600
REDIS_MAX_CONNECTIONS=50

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_SEARCH_TIMEOUT_MS=80
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_COALESCING_LOCK_TTL_SECONDS=10
CACHE_COALESCING_WAIT_SECONDS=2
CACHE_COALESCING_POLL_INTERVAL_SECONDS=0.05

# --- Embeddings (pluggable: local sentence-transformers by default) ---
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_API_MODEL_NAME=text-embedding-3-small

# --- Upstream LLM providers ---
# No quotes around API keys — Docker env_file passes values literally.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PROVIDER_FALLBACK_CHAIN=["openai","anthropic"]
PROVIDER_MAX_RETRIES=3
PROVIDER_REQUEST_TIMEOUT_SECONDS=60

# --- Background jobs ---
ARQ_REDIS_URL=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=llmops-gateway
TRACING_ENABLED=true
METRICS_ENABLED=true
COST_PRICING_CACHE_TTL_SECONDS=300

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Auth / rate limiting ---
API_KEY_HEADER_NAME=X-API-Key
AUTH_API_KEY_PEPPER=dev-insecure-pepper-change-me
AUTH_CACHE_TTL_SECONDS=300
AUTH_REQUIRE_API_KEY=true
DEFAULT_RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ENABLED=true
USE_ARQ_WORKERS=true
RUN_MIGRATIONS_ON_STARTUP=true
